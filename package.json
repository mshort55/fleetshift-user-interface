{
  "name": "fleetshift-user-interface",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,plugins,gui -c blue,magenta,green \"npm run dev:server\" \"npm run dev:plugins\" \"npm run dev:gui\"",
    "dev:server": "npm run dev -w packages/mock-servers",
    "dev:plugins": "npm run serve -w packages/mock-ui-plugins",
    "dev:gui": "npm run dev -w packages/gui",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "test:e2e": "npm test --workspace=packages/e2e"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "joi": "^18.0.2",
    "json-parse-even-better-errors": "^5.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "immutable": "^5.1.5"
  }
}
