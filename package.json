{
  "name": "fleetshift-user-interface",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:all": "npm run build -w packages/common && npm run build -w packages/mock-ui-plugins && npm run build -w packages/gui && node scripts/merge-web.mjs",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "test": "vitest run",
    "test:e2e": "npm test --workspace=packages/e2e"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
