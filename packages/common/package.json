{
  "name": "@fleetshift/common",
  "description": "Shared types and fetch helpers for FleetShift packages.",
  "version": "0.0.0",
  "private": true,
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./generated/pf-icons.json": "./src/generated/pf-icons.json"
  },
  "scripts": {
    "prebuild": "node ../../scripts/generate-icons.mjs",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json && echo '{\"type\":\"module\"}' > dist/esm/package.json"
  },
  "devDependencies": {
    "@types/react": "^19.1.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-router-dom": "^7",
    "@scalprum/react-core": "^0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-router-dom": { "optional": true },
    "@scalprum/react-core": { "optional": true }
  }
}
