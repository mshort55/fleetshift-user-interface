{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "jsx": "react-jsx",
    "typeRoots": ["../../node_modules/@types"],
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "ink": ["../../node_modules/ink/build/index.d.ts"],
      "@inkjs/ui": ["../../node_modules/@inkjs/ui/build/index.d.ts"]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node",
      "plugins": []
    }
  },
  "include": ["src"]
}
