    "@patternfly/react-core": "^6.5.1",
    "@patternfly/react-data-view": "^6.5.0",
    "@patternfly/react-icons": "^6.5.1",
    "@patternfly/react-log-viewer": "^6.4.0",
    "@patternfly/react-table": "^6.5.1",
    "@patternfly/widgetized-dashboard": "^1.0.0-prerelease.6",
    "@scalprum/core": "^0.9.2",
    "@scalprum/react-core": "^0.11.2",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "immutable": "^5.1.5",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.23",
    "motion": "^12.0.0",
    "oidc-client-ts": "^3.5.0",
