{
  "name": "@fleetshift/mock-ui-plugins",
  "description": "Webpack Module Federation remote plugins — built and served by the Go backend.",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "rm -rf dist node_modules/.cache && webpack",
    "build:ci": "rm -rf dist node_modules/.cache && for name in overview management core signing routing gcphcp kind configuration virtualization security observability settings; do echo \"--- $name ---\" && webpack --config-name $name || exit 1; done",
    "watch": "webpack --watch"
  },
  "dependencies": {
    "@fleetshift/common": "*",
    "@patternfly/react-charts": "^8.5.1",
    "@patternfly/react-code-editor": "^6.5.1",
